TELEGRAM_BOT_TOKEN=
# Имя бота без @ — для кнопки «Войти через Telegram» на сайте (раздел Аккаунт → привязка к mini app)
# TELEGRAM_BOT_USERNAME=YourBotName
#
# --- Продакшен (один домен, API на VPS: nginx → miniapp/run.py :8000) ---
# PUBLIC_BASE_URL=https://your-domain.ru
# TELEGRAM_PUBLIC_BASE_URL=https://your-domain.ru
# WEBSITE_URL=                     # пусто = та же база; или явно https://your-domain.ru
#
# Локально:
# PUBLIC_BASE_URL=http://127.0.0.1:8000
# Для кнопки Web App в Telegram нужен HTTPS: прод-домен или свой туннель/ngrok и т.п.
PUBLIC_BASE_URL=http://127.0.0.1:8000
# Публичный HTTPS для кнопок бота (на проде совпадает с доменом сайта)
# TELEGRAM_PUBLIC_BASE_URL=https://your-domain.ru
# Кнопка «Сайт» — корень сайта, не /miniapp/
WEBSITE_URL=
# Подписи кнопок в /start (необязательно; по умолчанию «Сайт» и «Мини-приложение»)
# WEBSITE_BUTTON_LABEL=Сайт
# MINIAPP_BUTTON_LABEL=Мини-приложение
JWT_SECRET=
# --- hh.ru (вакансии, подсказки городов) ---
# User-Agent с контактом разработчика — как в заявке на https://dev.hh.ru/admin
# HH_USER_AGENT=VibeWork/1.0 (you@example.com)
# После одобрения заявки — OAuth client_credentials (или готовый HH_APP_ACCESS_TOKEN):
# HH_CLIENT_ID=
# HH_CLIENT_SECRET=
# HH_APP_ACCESS_TOKEN=
# Проверка после перезапуска API: GET /api/health/hh или python scripts/test_hh_api.py
# Сброс пароля: Resend (https://resend.com). Домен в EMAIL_FROM должен быть верифицирован в Resend.
# EMAIL_FROM="VibeWork <noreply@your-domain.ru>"
# RESEND_API_KEY=
# RESEND_BASE_URL=https://api.resend.com
# Необязательно: полный путь к SQLite (по умолчанию miniapp/data/career.db)
# DATABASE_PATH=

# --- LLM: облако или локальный OpenAI-совместимый сервер ---
# CHAT_API_KEY=
# CHAT_API_URL=https://api.groq.com/openai/v1/chat/completions
# CHAT_MODEL=llama-3.1-8b-instant
# или DEEPSEEK_API_KEY / DEEPSEEK_API_URL / OPENAI_* — см. llm_client.py
# Локально без ключа: CHAT_API_URL=http://127.0.0.1:11434/v1/chat/completions (если поднят совместимый сервер)
# Долгий первый ответ к локальному URL: LLM_LOCAL_TIMEOUT=180
# После правок .env перезапустите API (miniapp/run.py).
