TELEGRAM_BOT_TOKEN=
# Имя бота без @ — для кнопки «Войти через Telegram» на сайте (раздел Аккаунт → привязка к mini app)
# TELEGRAM_BOT_USERNAME=YourBotName
#
# --- Продакшен (один домен, API на VPS: nginx → miniapp/run.py :8000) ---
# PUBLIC_BASE_URL=https://your-domain.ru
# TELEGRAM_PUBLIC_BASE_URL=https://your-domain.ru
# WEBSITE_URL=                     # пусто = та же база; или явно https://your-domain.ru
#
# Локально без туннеля API:
# PUBLIC_BASE_URL=http://127.0.0.1:8000
# Для кнопки Web App в Telegram нужен HTTPS. Локально: Cloudflare Quick Tunnel (launch-stack → cloudflared)
# или тот же прод-домен. Хост: python miniapp/run.py — не указывайте сюда изолированный website :8765 без full stack.
PUBLIC_BASE_URL=http://127.0.0.1:8000
# Публичный HTTPS для кнопок бота (при quick tunnel подставляется cloudflared; на проде = домен)
# TELEGRAM_PUBLIC_BASE_URL=https://xxxx.trycloudflare.com
# Кнопка «Сайт» — корень сайта, не /miniapp/
WEBSITE_URL=
# Подписи кнопок в /start (необязательно; по умолчанию «Сайт» и «Мини-приложение»)
# WEBSITE_BUTTON_LABEL=Сайт
# MINIAPP_BUTTON_LABEL=Мини-приложение
JWT_SECRET=
# Необязательно: полный путь к SQLite (по умолчанию miniapp/data/career.db)
# DATABASE_PATH=

# --- LLM: локальная Ollama (без облачного ключа) ---
# Запустите Ollama, подтяните модель: ollama pull <имя>
# USE_OLLAMA=1
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5:7b
# Первый ответ может быть долгим: LLM_LOCAL_TIMEOUT=180
#
# --- LLM: облако (OpenAI-совместимый API) ---
# CHAT_API_KEY=
# или DEEPSEEK_API_KEY= (альтернатива CHAT_API_KEY для DeepSeek)
# CHAT_API_URL=https://api.deepseek.com/v1/chat/completions
# CHAT_MODEL=deepseek-chat
# Совместимость: DEEPSEEK_*; OPENAI_*.
# Альтернатива Ollama без USE_OLLAMA: CHAT_API_URL=http://127.0.0.1:11434/v1/chat/completions (ключ не нужен).
# После правок .env перезапустите API (miniapp/run.py).
