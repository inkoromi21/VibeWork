TELEGRAM_BOT_TOKEN=
# Для кнопки Web App в Telegram нужен HTTPS. Локально: Cloudflare Tunnel (launch-stack → окно cloudflared)
# или свой домен / VPS. Укажите публичный базовый URL:
# PUBLIC_BASE_URL=https://xxxx.trycloudflare.com
# Хост процесса wibe_work.main: python miniapp/run.py (:8000) ИЛИ website/main.py с VIBEWORK_FULL_STACK=1.
# НЕ указывайте сюда только изолированный website (:8765 без полного стека) — не будет /miniapp/ и API мини-приложения.
PUBLIC_BASE_URL=http://127.0.0.1:8000
# Публичный HTTPS для кнопок бота (заполняется автоматически при запуске cloudflared из launch-stack, либо впишите вручную)
# TELEGRAM_PUBLIC_BASE_URL=https://xxxx.trycloudflare.com
# Кнопка «Сайт» в боте — корень веб-версии. Не указывайте /miniapp/
WEBSITE_URL=http://127.0.0.1:8000
# Подписи кнопок в /start (необязательно; по умолчанию «Сайт» и «Мини-приложение»)
# WEBSITE_BUTTON_LABEL=Сайт
# MINIAPP_BUTTON_LABEL=Мини-приложение
JWT_SECRET=
# Необязательно: полный путь к SQLite (по умолчанию miniapp/data/career.db)
# DATABASE_PATH=

# --- LLM: локальная Ollama (без облачного ключа) ---
# Запустите Ollama, подтяните модель: ollama pull <имя>
# USE_OLLAMA=1
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5:7b
# Первый ответ может быть долгим: LLM_LOCAL_TIMEOUT=180
#
# --- LLM: облако (OpenAI-совместимый API) ---
# CHAT_API_KEY=
# или DEEPSEEK_API_KEY= (альтернатива CHAT_API_KEY для DeepSeek)
# CHAT_API_URL=https://api.deepseek.com/v1/chat/completions
# CHAT_MODEL=deepseek-chat
# Совместимость: DEEPSEEK_*; OPENAI_*.
# Альтернатива Ollama без USE_OLLAMA: CHAT_API_URL=http://127.0.0.1:11434/v1/chat/completions (ключ не нужен).
# После правок .env перезапустите API (miniapp/run.py).
