# Скопируйте в корень репозитория на VPS как .env (рядом с miniapp/), либо задайте путь через переменную окружения процесса:
# VIBEWORK_ENV_FILE=/opt/vibework/.env
TELEGRAM_BOT_TOKEN=PASTE_FROM_BOTFATHER
# Имя бота без @ — для виджета входа Telegram на сайте (привязка аккаунта)
TELEGRAM_BOT_USERNAME=VibeWorks_bot
PUBLIC_BASE_URL=https://vibeworkrussia.ru
# Сброс пароля: Resend (HTTPS API). EMAIL_FROM — адрес на верифицированном в Resend домене.
EMAIL_FROM=VibeWork <noreply@vibeworkrussia.ru>
RESEND_API_KEY=
RESEND_BASE_URL=https://api.resend.com
TELEGRAM_PUBLIC_BASE_URL=https://vibeworkrussia.ru
WEBSITE_URL=
JWT_SECRET=PASTE_LONG_RANDOM_STRING
# Админ-панель: https://your-domain.ru/admin
ADMIN_LOGIN=
ADMIN_PASSWORD=
# hh.ru: формат «ИмяПриложения/версия (реальный@email)»; без валидного User-Agent часто 403.
# Если ВПС не в РФ или провайдер режет api.hh.ru — задайте HTTPS_PROXY (выход в РФ) или смените хостинг.
HH_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/125.0.0.0 Safari/537.36 VibeWork/1.0 (sema.vorobev20078@gmail.com)
# Токен приложения: https://dev.hh.ru/admin — либо готовый access_token, либо пара client_id/client_secret (OAuth client_credentials на https://api.hh.ru/token).
# HH_APP_ACCESS_TOKEN=
# HH_CLIENT_ID=
# HH_CLIENT_SECRET=
# HTTPS_PROXY=http://127.0.0.1:8118

CHAT_API_KEY=PASTE_GROQ_API_KEY
CHAT_API_URL=https://api.groq.com/openai/v1/chat/completions
CHAT_MODEL=llama-3.1-8b-instant
