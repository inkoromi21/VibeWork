# Скопируйте в .env в корне репозитория (рядом с docker-compose.yml).
# Для Docker: cp .env.example .env && docker compose up --build
# Полный список: docs/ENV.md

VIBEWORK_ENV=dev
PUBLIC_BASE_URL=http://127.0.0.1:8000
CORS_ALLOW_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
# DATABASE_PATH=   # локально — по умолчанию miniapp/data/; в Docker задаётся в docker-compose.yml

# JWT (для локальной проверки достаточно dev-значения)
JWT_SECRET=dev-change-me-in-production-vibework

# hh.ru (демо-вакансии работают и без OAuth; для API укажите User-Agent с email из заявки)
HH_USER_AGENT=VibeWork/1.0 (you@example.com)

# --- ИИ-чат и разбор (опционально; без ключей UI работает, LLM — заглушки) ---
# USE_OLLAMA=0
# CHAT_API_URL=https://ollama.com/v1/chat/completions
# CHAT_API_KEY=
# CHAT_MODEL=gpt-oss:120b-cloud

# --- Telegram (опционально; бот запускается отдельно: python miniapp/bot/bot.py) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_PUBLIC_BASE_URL=https://your-domain

# --- Почта / админка (опционально) ---
# EMAIL_FROM=
# RESEND_API_KEY=
# ADMIN_LOGIN=
# ADMIN_PASSWORD=
