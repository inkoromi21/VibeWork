# Скопируйте в файл .env в корне проекта (рядом с main.py).
# Загрузка: python-dotenv подхватит автоматически при старте backend.

# --- Реальная нейросеть в чате и в тексте разбора (OpenAI-совместимый API) ---

# Вариант 1: DeepSeek (дешёвый, хорош по-русски)
# Получить ключ: https://platform.deepseek.com
DEEPSEEK_API_KEY=
# Опционально:
# DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
# DEEPSEEK_MODEL=deepseek-chat

# Вариант 2: явные переменные (удобно для любого провайдера)
# CHAT_API_KEY=sk-...
# CHAT_API_URL=https://api.deepseek.com/v1/chat/completions
# CHAT_MODEL=deepseek-chat

# Вариант 3: OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# (URL подставится сам: https://api.openai.com/v1/chat/completions)

# Вариант 4: локальный OpenAI-совместимый сервер (127.0.0.1)
# CHAT_API_URL=http://127.0.0.1:11434/v1/chat/completions
# CHAT_MODEL=...
# CHAT_API_KEY не нужен, если сервер не требует Bearer

# Проверка после запуска сервера: GET http://127.0.0.1:8765/api/health/llm
# Ожидается {"llm_configured": true}

# --- Вакансии: API hh.ru (документация: https://api.hh.ru/openapi/redoc) ---
# Обязательный формат User-Agent по правилам hh.ru; укажите свой контакт:
# HH_USER_AGENT=VibeWork/1.0 (you@example.com)
# HH_VACANCIES_DISABLED=0   # 1 — только демо-вакансии без запросов к hh.ru
# HH_REQUEST_TIMEOUT=22
